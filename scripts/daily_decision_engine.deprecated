#!/usr/bin/env python3
"""
🔥 实战决策引擎 v1.0
=====================
终极目标：把2年+30,000次回测浓缩成每天可执行的操作单

数据源：
  1. 腾讯实时行情 (qt.gtimg.cn) — 盘中实时
  2. kline_cache.db — 涨停前趋势、MA20乖离、量比
  3. sector_indexes.db — 板块强弱排名
  4. holder_cache.db — 牛散持股
  5. trade_sim.db — 当前持仓

输出：
  微信推送格式的操作单：
  - 买入候选（按优先级排序）
  - 卖出信号（按紧急程度排序）
  - 持有建议
  - 大盘环境+仓位建议
"""

import os, sys, json, subprocess, re, time
from datetime import datetime, date
from collections import defaultdict

BASE = os.path.expanduser('~/astock')
DATA_DIR = os.path.join(BASE, 'data')
SCRIPTS = os.path.join(BASE, 'scripts')
V2BOARD = os.path.expanduser('~/V2board')
sys.path.insert(0, SCRIPTS)

def classify_market(total_limit, max_board, idx_chg_5d):
    """7行情宏观分类"""
    if total_limit < 10: return '冰点'
    if total_limit < 20 and idx_chg_5d < -2: return '深度退潮'
    if total_limit < 25: return '退潮'
    if total_limit >= 50 and max_board >= 4: return '主升浪'
    if total_limit >= 40 and max_board >= 4: return '发酵期'
    if total_limit >= 40: return '活跃期'
    if total_limit >= 25: return '震荡期'
    return '弱势震荡'

MARKET_ORDER = ['冰点', '深度退潮', '退潮', '震荡期', '活跃期', '发酵期', '主升浪']
YOUZI_TYPES = ('34', '37', '38', '39', '40')

def load_market_micro_signals():
    """加载龙虎榜游资趋势数据（最近10天）"""
    try:
        # 使用子查询避免交易方向重复计算
        r = subprocess.run(['sqlite3', '-json', os.path.join(DATA_DIR, 'lhb_cache.db')],
            input="""
                SELECT date,
                  ROUND(SUM(CASE WHEN direction='buy' THEN net ELSE 0 END)/10000, 0) as buy_wan,
                  ROUND(SUM(CASE WHEN direction='sell' THEN net ELSE 0 END)/10000, 0) as sell_wan,
                  ROUND((SUM(CASE WHEN direction='buy' THEN net ELSE 0 END) - SUM(CASE WHEN direction='sell' THEN net ELSE 0 END))/10000, 0) as net_wan,
                  COUNT(DISTINCT code) as stocks
                FROM (
                  SELECT l.date, l.code, d.direction, d.net
                  FROM lhb_list l
                  JOIN lhb_detail d ON l.date=d.date AND l.code=d.code
                  WHERE l.type IN ('34','37','38','39','40')
                  AND l.date >= date('now', '-10 days')
                )
                GROUP BY date ORDER BY date
            """.strip(),
            capture_output=True, text=True, timeout=10
        )
        raw = json.loads(r.stdout) if r.stdout.strip() else []
    except Exception as e:
        print(f"  微观数据加载异常: {e}")
        return []
    
    result = []
    for item in raw:
        result.append({
            'date': item['date'],
            'youzi_net': item['net_wan'] * 10000,  # 转回元
            'youzi_ratio': 50,  # 不再使用买入比，用净额方向代替
            'buy_sell_ratio': 1,
        })
    return result

def calc_youzi_trend(micro_data):
    """计算游资3日趋势（数据从早到晚排列）"""
    if len(micro_data) < 3: return '数据不足'
    nets = [d['youzi_net'] for d in micro_data[-3:]]
    # nets[0]=最旧, nets[2]=最新
    if nets[2] > nets[1] > nets[0]:
        return '持续上升'
    elif nets[2] < nets[1] < nets[0]:
        return '持续下降'
    elif nets[2] > nets[0]:
        return '震荡偏强'
    else:
        return '震荡偏弱'

def get_market_advice(macro_cls, youzi_trend, youzi_ratio, total_limit, max_board, micro_data):
    """宏观+微观融合决策"""
    advice_lines = []
    signal_lines = []
    
    # 宏观策略
    if macro_cls == '冰点':
        advice_lines.append('⛔ 空仓 — 涨停<10只，无操作空间')
        signal_lines.append('⚪ 冰点: 不做')
        max_position = 0
    elif macro_cls == '深度退潮':
        advice_lines.append('⚠️ 深度退潮 — 只做总龙头(回测+5.76%胜87%)')
        signal_lines.append('🟡 抱团: 只做龙头')
        max_position = '0~10%'
    elif macro_cls == '退潮':
        advice_lines.append('🌫️ 退潮 — 隔夜溢价(极缩优先)')
        signal_lines.append('🟡 观望: 隔夜溢价')
        max_position = '10~20%'
    elif macro_cls == '震荡期':
        advice_lines.append('⚖️ 震荡期(30%时间) — 只做隔夜溢价(+4.18%胜76%)')
        signal_lines.append('🟢 稳做: 隔夜溢价')
        max_position = '20~40%'
    elif macro_cls == '活跃期':
        advice_lines.append('☀️ 活跃期 — 隔夜溢价为主(+4.03%胜84%)')
        signal_lines.append('🟢 积极: 隔夜溢价')
        max_position = '40~60%'
    elif macro_cls == '发酵期':
        advice_lines.append('⚡ 发酵期(21%时间) — 双策略并行(隔夜+4.61% 龙头+3.67%)')
        signal_lines.append('🟣 加仓: 隔夜+龙头')
        max_position = '50~70%'
    elif macro_cls == '主升浪':
        advice_lines.append('🌊 主升浪(27%时间) — 全仓隔夜溢价(+4.79%胜83%)')
        signal_lines.append('🔴 满仓: 隔夜溢价')
        max_position = '70~100%'
    
    # 微观预警（基于游资净额趋势）
    if micro_data and len(micro_data) >= 3:
        recent_nets = [m['youzi_net']/10000 for m in micro_data[-3:]]
        # 净额方向
        if youzi_trend == '持续上升':
            advice_lines.append(f'🟢 游资连续加仓({recent_nets[0]:.0f}→{recent_nets[2]:.0f}万) — 资金在进场')
        elif youzi_trend == '持续下降':
            advice_lines.append(f'🔴 游资连续减仓({recent_nets[0]:.0f}→{recent_nets[2]:.0f}万) — 资金在撤退')
        
        # 顶部预警：之前上升现在转下降
        if youzi_trend in ('持续下降', '震荡偏弱'):
            prev_trend = calc_youzi_trend(micro_data[:-1]) if len(micro_data) >= 4 else ''
            if prev_trend in ('持续上升', '震荡偏强'):
                advice_lines.append('🔴⚠️ 顶部预警！游资从买入转卖出，3天内行情可能见顶')
                signal_lines.append('🔴 减仓: 游资撤退')
        
        # 底部信号：之前下降现在转上升
        if youzi_trend in ('持续上升', '震荡偏强'):
            prev_trend = calc_youzi_trend(micro_data[:-1]) if len(micro_data) >= 4 else ''
            if prev_trend in ('持续下降', '震荡偏弱'):
                advice_lines.append('🟢🚀 底部信号！游资开始进场，3天内行情可能回暖')
                signal_lines.append('🟢 加仓: 游资进场')
    
    # 净额极值预警
    if micro_data:
        last_net = micro_data[-1]['youzi_net'] / 10000
        if last_net > 200:
            advice_lines.append(f'🟡 游资大额买入{last_net:.0f}万 — 市场过热')
            signal_lines.append('🟡 过热')
        elif last_net < -200:
            advice_lines.append(f'🔴 游资大额卖出{last_net:.0f}万 — 恐慌抛售')
            signal_lines.append('🔴 恐慌')
    
    return advice_lines, signal_lines, max_position

def get_lhb_data_simple():
    """获取最近5天龙虎榜数据用于显示"""
    try:
        r = subprocess.run(['sqlite3', '-json', os.path.join(DATA_DIR, 'lhb_cache.db')],
            input="""
                SELECT l.date, COUNT(DISTINCT l.code) as stocks,
                  ROUND(SUM(CASE WHEN d.direction='buy' THEN d.net ELSE 0 END)/10000, 0) as total_buy_wan,
                  ROUND(SUM(CASE WHEN d.direction='sell' THEN d.net ELSE 0 END)/10000, 0) as total_sell_wan
                FROM lhb_list l
                JOIN lhb_detail d ON l.date=d.date AND l.code=d.code
                WHERE l.date >= date('now', '-7 days')
                GROUP BY l.date ORDER BY l.date
            """.strip(),
            capture_output=True, text=True, timeout=8
        )
        return json.loads(r.stdout) if r.stdout.strip() else []
    except:
        return []

