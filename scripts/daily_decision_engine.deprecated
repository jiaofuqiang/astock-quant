    """获取今日板块爆发数据"""
    try:
        r = subprocess.run(['sqlite3', '-json', os.path.join(DATA_DIR, 'sector_indexes.db')],
            input="SELECT date, sector, boom_count FROM sector_daily_index WHERE date=(SELECT MAX(date) FROM sector_daily_index) AND boom_count>=3 ORDER BY boom_count DESC LIMIT 5",
            capture_output=True, text=True, timeout=5
        )
