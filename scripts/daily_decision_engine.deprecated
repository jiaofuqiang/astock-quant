def get_limit_strength_today():
    """获取今日涨停数+最高板（从kline_cache推算）"""
    try:
        r = subprocess.run(['sqlite3', '-json', os.path.join(DATA_DIR, 'daily_limit_data.db')],
            input="SELECT date, total_limit, max_board FROM limit_strength WHERE date=(SELECT MAX(date) FROM limit_strength)",
            capture_output=True, text=True, timeout=5
        )
        data = json.loads(r.stdout) if r.stdout.strip() else []
        if data: return data[0]
    except:
        pass
    return None

